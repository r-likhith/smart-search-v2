# ─── MEILISEARCH ──────────────────────────────────────────
# Use localhost for local dev, http://meilisearch:7700 for Docker
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=your_meili_master_key_here

# ─── SERVER ───────────────────────────────────────────────
PORT=3000
API_KEY=your_api_key_here

# ─── ELASTICSEARCH (optional) ─────────────────────────────
ES_NODE=http://your_es_host:port
ES_USERNAME=your_es_username
ES_PASSWORD=your_es_password
CLIENT_INDEX=client_198_products

# ─── DELTA SYNC ───────────────────────────────────────────
ENABLE_DELTA_SYNC=false
SYNC_WEBHOOK_SECRET=your_webhook_secret_here

# ─── SEARCH FEATURE FLAGS ─────────────────────────────────
RETRIEVAL_CORRECTION=true
COSMETIC_CORRECTION=true
CORRECTION_BANNER=true
SEARCH_INSTEAD_LINK=true
SILENT_CORRECTION=false

# ─── OFFLINE LEARNER ──────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
